<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="club.boyuan.official.mapper.ResumeFieldValueMapper">

    <resultMap id="ResumeFieldValueMap" type="club.boyuan.official.entity.ResumeFieldValue">
        <id column="value_id" property="valueId"/>
        <result column="resume_id" property="resumeId"/>
        <result column="field_id" property="fieldId"/>
        <result column="field_value" property="fieldValue"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <!-- 自定义查询方法 -->
    <select id="findByResumeId" parameterType="java.lang.Integer" resultMap="ResumeFieldValueMap">
        SELECT * FROM resume_field_value
        WHERE resume_id = #{resumeId}
    </select>

    <select id="findByResumeIdAndFieldId" resultMap="ResumeFieldValueMap">
        SELECT * FROM resume_field_value
        WHERE resume_id = #{resumeId} AND field_id = #{fieldId}
    </select>

    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO resume_field_value (resume_id, field_id, field_value, created_at, updated_at)
        VALUES
        <foreach collection="fieldValues" item="item" separator=",">
            (#{item.resumeId}, #{item.fieldId}, #{item.fieldValue}, NOW(), NOW())
        </foreach>
    </insert>

    <update id="update" parameterType="club.boyuan.official.entity.ResumeFieldValue">
        UPDATE resume_field_value
        <set>
            <if test="fieldValue != null">field_value = #{fieldValue},</if>
            <if test="fieldValue != null">updated_at = NOW(),</if>
        </set>
        WHERE value_id = #{valueId}
    </update>

    <update id="batchUpdate" parameterType="java.util.List">
        <foreach collection="fieldValues" item="item" separator=";">
            UPDATE resume_field_value
            <set>
                <if test="item.fieldValue != null">field_value = #{item.fieldValue},</if>
                updated_at = NOW()
            </set>
            WHERE value_id = #{item.valueId}
        </foreach>
    </update>

    <delete id="deleteByResumeId" parameterType="java.lang.Integer">
        DELETE FROM resume_field_value
        WHERE resume_id = #{resumeId}
    </delete>

    <delete id="deleteByFieldId" parameterType="java.lang.Integer">
        DELETE FROM resume_field_value
        WHERE field_id = #{fieldId}
    </delete>

</mapper>